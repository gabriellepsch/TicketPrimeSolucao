@page "/cadastro"
@using Microsoft.AspNetCore.Components.Forms
@using billet_2.Models
@rendermode RenderMode.InteractiveServer
@inject NavigationManager Navigation
@inject billet_2.Services.UsuarioService UsuarioService

@* --- 1. BARRA DE TOPO --- *@
<nav class="navbar-top">
    <a href="/" class="brand-button">BiLleT*</a>
</nav>

@* --- 2. CONTAINER DE CADASTRO --- *@
<div class="registration-container">
    <div class="registration-card shadow-sm">
        
        <h2 class="text-center mb-2 fw-bold" style="font-family: 'TanNimbus', sans-serif; color: #333;">Criar Conta</h2>
        <p class="text-center text-muted mb-5">Junte-se à inovação em eventos.</p>

        @if (!string.IsNullOrEmpty(mensagemErro))
        {
            <div class="alert alert-danger py-2 small">@mensagemErro</div>
        }

        @if (cadastroSucesso)
        {
            <div class="alert alert-success">Usuário criado! Redirecionando...</div>
        }
        else
        {
            @* Usando EditForm do Git para validar os dados *@
            <EditForm Model="usuario" OnValidSubmit="HandleCadastro" FormName="CadastroUsuario">
                
                <div class="mb-4">
                    <label class="form-label fw-semibold">Nome Completo</label>
                    <InputText @bind-Value="usuario.Nome" class="form-control custom-input" placeholder="Digite seu nome" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">E-mail</label>
                    <InputText @bind-Value="usuario.Email" type="email" class="form-control custom-input" placeholder="seu@email.com" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">CPF</label>
                    @* Campo novo que veio do Git *@
                    <InputText @bind-Value="usuario.Cpf" class="form-control custom-input" placeholder="000.000.000-00" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Senha</label>
                    <InputText @bind-Value="usuario.Senha" type="password" class="form-control custom-input" placeholder="Senha segura" />
                </div>

                @* --- LÓGICA DE ADMIN (SEU DIFERENCIAL) --- *@
                <div class="mb-4 d-flex align-items-center gap-2">
                    <input type="checkbox" id="checkAdmin" @bind="isAdmin" style="width: 18px; height: 18px; cursor: pointer;" />
                    <label for="checkAdmin" class="fw-semibold m-0" style="cursor: pointer; color: #555;">Sou Administrador</label>
                </div>

                @if (isAdmin)
                {
                    <div class="mb-4 admin-field-animation">
                        <label class="form-label fw-bold" style="color: #808080;">CHAVE SECRETA</label>
                        <input type="password" class="form-control custom-input" placeholder="Chave Mestra"
                               @bind="adminSecretInput" @bind:event="oninput" />
                    </div>
                }

                <button type="submit" class="btn-finalizar" disabled="@carregando">
                    @(carregando ? "Processando..." : "Finalizar Cadastro")
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    private Usuario usuario = new(); // Model do Git
    private bool isAdmin = false;
    private string adminSecretInput = "";
    private string mensagemErro = "";
    private bool cadastroSucesso = false;
    private bool carregando = false;

    private const string MASTER_KEY = "BILLET2026";

    private async Task HandleCadastro()
    {
        mensagemErro = "";
        
        // 1. Validação da sua chave de Admin antes de chamar a API
        if (isAdmin && adminSecretInput != MASTER_KEY)
        {
            mensagemErro = "Chave mestra incorreta!";
            return;
        }

        carregando = true;

        // 2. Chama o Service do Git para salvar no Banco de Dados
        var erroRetornado = await UsuarioService.CadastrarAsync(usuario);

        if (string.IsNullOrEmpty(erroRetornado))
        {
            cadastroSucesso = true;
            StateHasChanged();
            await Task.Delay(1500);
            Navigation.NavigateTo("/poslogin");
        }
        else
        {
            mensagemErro = erroRetornado;
        }

        carregando = false;
    }
}