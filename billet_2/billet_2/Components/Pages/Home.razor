@page "/"
@using billet_2.Models
@inject billet_2.Services.EventoService EventoService

<div class="page-container">
    @* --- SEÇÃO 1: HERO BANNER (VÍDEO) --- *@
    <section class="hero-section">
        <div class="video-wrapper">
            <video autoplay loop muted playsinline class="video-element">
                <source src="videos/video1.mp4" type="video/mp4" />
                Seu navegador não suporta vídeos.
            </video>
            <div class="video-overlay"></div>
        </div>

        <div class="hero-content">
            <div class="container text-center text-white">
                <h1 class="hero-title">B i L l e T *</h1>
                <p class="hero-text">
                    O Billet não é apenas uma plataforma de vendas; é o ponto de encontro entre quem cria e quem vive
                    momentos inesquecíveis.
                </p>
                <hr class="hero-hr" />
                <a href="/cadastro" class="btn-hero">Faça seu cadastro e seja família Billet *</a>
            </div>
        </div>
    </section>

    @* --- SEÇÃO 2: EVENTOS DINÂMICOS --- *@
    <section class="events-section">
        <div class="container py-5">
            <h2 class="section-title">Nossos eventos ↷</h2>
            
            <div class="row g-4">
                @if (eventos == null)
                {
                    @* Shimmer ou Loading enquanto a API não responde *@
                    <p class="text-center w-100">Carregando eventos incríveis...</p>
                }
                else if (!eventos.Any())
                {
                    <p class="text-center w-100">Nenhum evento disponível no momento. Volte logo!</p>
                }
                else
                {
                    @foreach (var evento in eventos)
                    {
                        <div class="col-12 col-md-4">
                            <div class="event-card shadow-sm">
                                <div class="event-img-cap">
                                    @if (!string.IsNullOrEmpty(evento.FotoUrl))
                                    {
                                        <img src="@evento.FotoUrl" alt="@evento.Nome" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">FOTO DO EVENTO</span>
                                    }
                                </div>
                                <div class="event-card-body">
                                    <h5>@evento.Nome</h5>
                                    <p>@evento.Descricao</p>
                                    <small>📍 @evento.Local - @evento.Data.ToString("dd/MM/yyyy")</small>
                                    
                                    @* Como é a Home (sem login), mandamos para o Cadastro ou Venda detalhada *@
                                    <a href="/vendas/@evento.Id" class="event-link">Ver ingressos →</a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    @* --- SEÇÃO 3: RODAPÉ --- *@
    <footer class="site-footer">
        <p>&copy; 2026 Billet - Todos os direitos reservados.</p>
    </footer>
</div>

@code {
    private List<Evento>? eventos;

    protected override async Task OnInitializedAsync()
    {
        // Puxa os dados reais da API/Banco via Service do Git
        eventos = await EventoService.ListarEventosAsync();
    }
}