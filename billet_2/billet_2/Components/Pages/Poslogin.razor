@page "/poslogin"
@using billet_2.Models
@inject billet_2.Services.EventoService EventoService
@inject NavigationManager Navigation
@inject billet_2.Services.AuthService AuthService
@rendermode RenderMode.InteractiveServer

@* --- 1. BARRA DE NAVEGAÇÃO --- *@
@if (!AuthService.EstaLogado)
{
    <p>Redirecionando...</p>
    Navigation.NavigateTo("/");
}else{
    <nav class="navbar-top">
        <a href="/poslogin" class="brand-button">BiLleT*</a>

        <div class="nav-actions-right">
            @if(@AuthService.UsuarioLogado!.Adm){
                <a href="/criarevento" class="nav-action-button create-btn">
                    Criar Evento ➕
                </a>
            }else{
                <a href="/meusingressos" class="nav-action-button">
                    Meus Ingressos 🎫
                </a>
            }

            <div class="profile-wrapper">
                <button class="nav-action-button create-btn" @onclick='ToggleDropdown' style="cursor:pointer;">
                    @AuthService.UsuarioLogado!.Nome 👤
                </button>

                @if (dropdownAberto)
                {
                    <div class="profile-dropdown">
                        <div class="dropdown-header">
                            <p class="dropdown-nome">@AuthService.UsuarioLogado!.Nome</p>
                            <p class="dropdown-email">@AuthService.UsuarioLogado!.Email</p>
                        </div>
                        <hr class="dropdown-divider" />
                        <button class="dropdown-item-sair" @onclick="Deslogar">
                            🚪 Sair
                        </button>
                    </div>
                }
            </div>
        </div>
    </nav>

    @* --- 2. SEÇÃO HERO (BANNER DINÂMICO) --- *@
    @if (eventoDestaque != null)
    {
        <div class="hero-container">
            @* Imagem de fundo desfocada - Puxando do Banco *@
            <img src="@(string.IsNullOrEmpty(eventoDestaque.FotoUrl) ? "default.jpg" : eventoDestaque.FotoUrl)"
                class="img-fundo-blur" alt="Fundo" />

            <div class="card-frente-container">
                <img src="@(string.IsNullOrEmpty(eventoDestaque.FotoUrl) ? "default.jpg" : eventoDestaque.FotoUrl)"
                    class="img-card-frente" alt="@eventoDestaque.Nome" />
                
                <div class="card-frente-info">
                    <h3>@eventoDestaque.Nome</h3>
                    <p>Destaque • @eventoDestaque.Data.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>
    }

    @* --- 3. SEÇÃO DE EVENTOS --- *@
    <section class="events-section">
        <div class="container py-5">
            <h2 class="section-title">Nossos eventos 🤓</h2>
            
            <div class="row g-4">
                @if (eventos == null)
                {
                    <div class="col-12 text-center">
                        <p class="text-muted">Sincronizando eventos com o banco...</p>
                    </div>
                }
                else if (!eventos.Any())
                {
                    <div class="col-12 text-center">
                        <p class="text-muted">Nenhum evento cadastrado no momento.</p>
                    </div>
                }
                else
                {
                    @foreach (var ev in eventos)
                    {
                        <div class="col-12 col-md-4">
                            <div class="event-card shadow-sm">
                                <div class="event-img-cap">
                                    @if (!string.IsNullOrEmpty(ev.FotoUrl))
                                    {
                                        <img src="@ev.FotoUrl" alt="@ev.Nome" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span>FOTO DO EVENTO</span>
                                    }
                                </div>
                                <div class="event-card-body">
                                    <h5>@ev.Nome</h5>
                                    <p>@ev.Descricao</p>
                                    <small>@ev.Local - @ev.Data.ToString("dd/MM/yyyy")</small>
                                    
                                    @* Passando o ID real do banco para a página de vendas *@
                                    <a href="/vendas/@ev.Id" class="event-link">Garantir Ingressos →</a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <footer class="site-footer">
        <p>&copy; 2026 Billet - Todos os direitos reservados.</p>
    </footer>
}
@code {
    private List<Evento>? eventos;
    private Evento? eventoDestaque;
    private bool dropdownAberto = false;

    private void ToggleDropdown()
    {
        dropdownAberto = !dropdownAberto;
    }

    private void Deslogar()
    {
        AuthService.Deslogar();
        Navigation.NavigateTo("/");
    }
    protected override async Task OnInitializedAsync()
    {
        // 1. Busca os dados reais usando o Service do Git
        eventos = await EventoService.ListarEventosAsync();

        // 2. Define o primeiro evento da lista como o destaque do banner Hero
        if (eventos != null && eventos.Any())
        {
            eventoDestaque = eventos.FirstOrDefault();
        }
    }
}