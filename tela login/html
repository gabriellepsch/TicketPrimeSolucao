<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TicketPrime — Entrar</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #07080d;
      --red: #e5202e;
      --red-glow: rgba(229,32,46,0.3);
      --gold: #c9a84c;
      --text: #f0ece4;
      --muted: #6b6b7e;
      --border: rgba(255,255,255,0.07);
      --surface: rgba(255,255,255,0.04);
    }

    html, body {
      height: 100%; width: 100%;
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow: hidden;
    }

    /* ── BACKGROUND ── */
    .bg-layer {
      position: fixed; inset: 0; z-index: 0;
      overflow: hidden;
    }
    /* film grain */
    .bg-layer::after {
      content: '';
      position: absolute; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 180px;
      opacity: 0.5;
      pointer-events: none;
    }

    .bg-gradient {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 50%, rgba(229,32,46,0.07) 0%, transparent 65%),
        radial-gradient(ellipse 60% 80% at 85% 15%, rgba(201,168,76,0.05) 0%, transparent 55%),
        radial-gradient(ellipse 50% 50% at 70% 85%, rgba(229,32,46,0.04) 0%, transparent 50%);
    }

    /* vertical filmstrip lines */
    .filmstrip {
      position: absolute; inset: 0;
      background-image:
        repeating-linear-gradient(90deg,
          rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px,
          transparent 1px, transparent 80px
        );
    }

    /* ── POSTER STRIP (left decoration) ── */
    .poster-strip {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 48%;
      display: flex;
      overflow: hidden;
    }
    .poster-col {
      flex: 1;
      display: flex; flex-direction: column; gap: 6px;
      padding: 0 3px;
    }
    .poster-col:nth-child(odd) { animation: drift-up 28s linear infinite; }
    .poster-col:nth-child(even) { animation: drift-down 32s linear infinite; }

    @keyframes drift-up {
      from { transform: translateY(0); }
      to   { transform: translateY(-50%); }
    }
    @keyframes drift-down {
      from { transform: translateY(-50%); }
      to   { transform: translateY(0); }
    }

    .mini-poster {
      flex-shrink: 0;
      border-radius: 8px;
      aspect-ratio: 2/3;
      width: 100%;
      opacity: 0.35;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .mp1  { background: linear-gradient(155deg,#2a0a0a,#6b1c1c); }
    .mp2  { background: linear-gradient(155deg,#0a0d2a,#1a2a6b); }
    .mp3  { background: linear-gradient(155deg,#0a1a10,#1a5a30); }
    .mp4  { background: linear-gradient(155deg,#1a140a,#5a3a0a); }
    .mp5  { background: linear-gradient(155deg,#180a1a,#4a0a5a); }
    .mp6  { background: linear-gradient(155deg,#0a1818,#0a404a); }
    .mp7  { background: linear-gradient(155deg,#1a0a14,#5a1030); }
    .mp8  { background: linear-gradient(155deg,#151010,#332020); }
    .mp9  { background: linear-gradient(155deg,#101520,#204060); }
    .mp10 { background: linear-gradient(155deg,#0f1a10,#204030); }

    /* left fade */
    .poster-fade {
      position: absolute; top: 0; bottom: 0; right: 0; width: 200px;
      background: linear-gradient(to right, transparent, var(--bg));
      pointer-events: none; z-index: 1;
    }

    /* ── LAYOUT ── */
    #app {
      position: relative; z-index: 1;
      width: 100vw; height: 100vh;
      display: flex; align-items: center; justify-content: flex-end;
      padding-right: 6vw;
    }

    /* ── CARD ── */
    .card {
      width: 420px;
      background: rgba(13,14,20,0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 44px 40px 36px;
      position: relative;
      animation: card-in 0.7s cubic-bezier(0.22,1,0.36,1) both;
    }
    @keyframes card-in {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* top accent line */
    .card::before {
      content: '';
      position: absolute; top: 0; left: 40px; right: 40px; height: 2px;
      background: linear-gradient(to right, transparent, var(--red), var(--gold), transparent);
      border-radius: 0 0 2px 2px;
    }

    /* ── LOGO ── */
    .logo {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 32px;
    }
    .logo-icon {
      width: 38px; height: 38px;
      background: var(--red);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      box-shadow: 0 0 20px var(--red-glow);
    }
    .logo-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 26px; letter-spacing: 2.5px;
      line-height: 1;
    }
    .logo-text span { color: var(--red); }

    /* ── TABS ── */
    .tabs {
      display: flex;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      border-radius: 10px; padding: 4px;
      margin-bottom: 28px;
    }
    .tab {
      flex: 1; padding: 9px;
      border: none; background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 600;
      cursor: pointer; border-radius: 7px;
      letter-spacing: 0.3px;
      transition: background 0.25s, color 0.25s, box-shadow 0.25s;
    }
    .tab.active {
      background: var(--red);
      color: #fff;
      box-shadow: 0 2px 14px var(--red-glow);
    }

    /* ── FORM SECTIONS ── */
    .form-section { display: none; }
    .form-section.active {
      display: block;
      animation: fade-up 0.35s ease both;
    }
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .form-heading {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px; letter-spacing: 1.5px;
      margin-bottom: 4px;
    }
    .form-sub {
      font-size: 13px; color: var(--muted);
      line-height: 1.6; margin-bottom: 24px;
    }

    .field { margin-bottom: 14px; }
    .field label {
      display: block;
      font-size: 11px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.8px;
      color: var(--muted); margin-bottom: 7px;
    }
    .field input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 11px 14px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .field input::placeholder { color: rgba(255,255,255,0.18); }
    .field input:focus {
      border-color: rgba(229,32,46,0.55);
      box-shadow: 0 0 0 3px rgba(229,32,46,0.08);
    }

    .field-row { display: flex; gap: 10px; }
    .field-row .field { flex: 1; }

    /* forgot */
    .row-between {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 8px; margin-top: -6px;
    }
    .row-between a {
      font-size: 12px; color: var(--gold);
      text-decoration: none; transition: color 0.2s;
    }
    .row-between a:hover { color: #e8c76a; }

    /* password strength */
    .strength-row {
      display: flex; gap: 4px; margin-top: 7px;
    }
    .strength-row span {
      flex: 1; height: 3px; border-radius: 2px;
      background: var(--border); transition: background 0.3s;
    }
    .str-weak  .strength-row span:nth-child(1) { background: var(--red); }
    .str-med   .strength-row span:nth-child(-n+2) { background: var(--gold); }
    .str-strong .strength-row span { background: #40c074; }

    /* checkbox */
    .check-field {
      display: flex; align-items: flex-start; gap: 10px; margin-bottom: 16px;
    }
    .check-field input[type="checkbox"] {
      width: 15px; height: 15px; margin-top: 2px;
      accent-color: var(--red); cursor: pointer; flex-shrink: 0;
    }
    .check-field label {
      font-size: 12px; color: var(--muted); line-height: 1.6; cursor: pointer;
    }
    .check-field label a { color: var(--gold); text-decoration: none; }

    /* submit */
    .btn-submit {
      width: 100%;
      background: var(--red);
      border: none; color: #fff;
      padding: 13px;
      border-radius: 9px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px; font-weight: 600;
      cursor: pointer; letter-spacing: 0.3px;
      transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
    }
    .btn-submit:hover { background: #c91b27; box-shadow: 0 4px 22px var(--red-glow); transform: translateY(-1px); }
    .btn-submit:active { transform: none; }

    /* divider */
    .divider {
      display: flex; align-items: center; gap: 10px; margin: 18px 0;
    }
    .divider span { flex: 1; height: 1px; background: var(--border); }
    .divider p { font-size: 11px; color: var(--muted); white-space: nowrap; }

    /* google */
    .btn-google {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 11px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 500;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 9px;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-google:hover { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.14); }

    /* footer */
    .card-footer {
      display: flex; align-items: center; justify-content: center; gap: 6px;
      margin-top: 22px; padding-top: 18px;
      border-top: 1px solid var(--border);
    }
    .card-footer .dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--red); opacity: 0.6;
    }
    .card-footer p {
      font-size: 11px; color: var(--muted); letter-spacing: 0.4px;
    }
  </style>
</head>
<body>

<!-- BACKGROUND -->
<div class="bg-layer">
  <div class="bg-gradient"></div>
  <div class="filmstrip"></div>

  <!-- animated poster columns -->
  <div class="poster-strip">
    <!-- col 1 -->
    <div class="poster-col">
      <div class="mini-poster mp1"></div><div class="mini-poster mp3"></div><div class="mini-poster mp5"></div>
      <div class="mini-poster mp7"></div><div class="mini-poster mp2"></div><div class="mini-poster mp9"></div>
      <!-- duplicate -->
      <div class="mini-poster mp1"></div><div class="mini-poster mp3"></div><div class="mini-poster mp5"></div>
      <div class="mini-poster mp7"></div><div class="mini-poster mp2"></div><div class="mini-poster mp9"></div>
    </div>
    <!-- col 2 -->
    <div class="poster-col">
      <div class="mini-poster mp4"></div><div class="mini-poster mp6"></div><div class="mini-poster mp8"></div>
      <div class="mini-poster mp10"></div><div class="mini-poster mp1"></div><div class="mini-poster mp5"></div>
      <div class="mini-poster mp4"></div><div class="mini-poster mp6"></div><div class="mini-poster mp8"></div>
      <div class="mini-poster mp10"></div><div class="mini-poster mp1"></div><div class="mini-poster mp5"></div>
    </div>
    <!-- col 3 -->
    <div class="poster-col">
      <div class="mini-poster mp2"></div><div class="mini-poster mp7"></div><div class="mini-poster mp3"></div>
      <div class="mini-poster mp9"></div><div class="mini-poster mp6"></div><div class="mini-poster mp4"></div>
      <div class="mini-poster mp2"></div><div class="mini-poster mp7"></div><div class="mini-poster mp3"></div>
      <div class="mini-poster mp9"></div><div class="mini-poster mp6"></div><div class="mini-poster mp4"></div>
    </div>
    <!-- col 4 -->
    <div class="poster-col">
      <div class="mini-poster mp5"></div><div class="mini-poster mp10"></div><div class="mini-poster mp1"></div>
      <div class="mini-poster mp8"></div><div class="mini-poster mp3"></div><div class="mini-poster mp6"></div>
      <div class="mini-poster mp5"></div><div class="mini-poster mp10"></div><div class="mini-poster mp1"></div>
      <div class="mini-poster mp8"></div><div class="mini-poster mp3"></div><div class="mini-poster mp6"></div>
    </div>
    <div class="poster-fade"></div>
  </div>
</div>

<!-- MAIN -->
<div id="app">
  <div class="card">

    <div class="logo">
      <div class="logo-icon">🎬</div>
      <div class="logo-text">TICKET<span>PRIME</span></div>
    </div>

    <div class="tabs">
      <button class="tab active" id="tab-login" onclick="switchTab('login')">Entrar</button>
      <button class="tab" id="tab-register" onclick="switchTab('register')">Cadastrar</button>
    </div>

    <!-- ── LOGIN ── -->
    <div class="form-section active" id="form-login">
      <div class="form-heading">Bem-vindo de volta</div>
      <div class="form-sub">Entre para reservar seus ingressos e acessar seus benefícios.</div>

      <div class="field">
        <label>E-mail</label>
        <input type="email" placeholder="seu@email.com"/>
      </div>

      <div class="field">
        <label>Senha</label>
        <input type="password" placeholder="••••••••"/>
      </div>

      <div class="row-between">
        <span></span>
        <a href="#">Esqueci minha senha</a>
      </div>

      <button class="btn-submit">Entrar</button>

      <div class="divider"><span></span><p>ou continue com</p><span></span></div>

      <button class="btn-google">
        <svg width="17" height="17" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908C16.658 14.013 17.64 11.705 17.64 9.2z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/></svg>
        Google
      </button>
    </div>

    <!-- ── CADASTRO ── -->
    <div class="form-section" id="form-register">
      <div class="form-heading">Crie sua conta</div>
      <div class="form-sub">Grátis e rápido. Comece a reservar seus filmes agora.</div>

      <div class="field-row">
        <div class="field">
          <label>Nome</label>
          <input type="text" placeholder="João"/>
        </div>
        <div class="field">
          <label>Sobrenome</label>
          <input type="text" placeholder="Silva"/>
        </div>
      </div>

      <div class="field">
        <label>E-mail</label>
        <input type="email" placeholder="seu@email.com"/>
      </div>

      <div class="field">
        <label>Telefone</label>
        <input type="tel" placeholder="(11) 99999-9999"/>
      </div>

      <div class="field" id="pass-field">
        <label>Senha</label>
        <input type="password" placeholder="Mínimo 8 caracteres" oninput="checkStrength(this)"/>
        <div class="strength-row">
          <span></span><span></span><span></span>
        </div>
      </div>

      <div class="check-field">
        <input type="checkbox" id="terms"/>
        <label for="terms">Concordo com os <a href="#">Termos de Uso</a> e a <a href="#">Política de Privacidade</a>.</label>
      </div>

      <button class="btn-submit">Criar conta</button>

      <div class="divider"><span></span><p>ou cadastre com</p><span></span></div>

      <button class="btn-google">
        <svg width="17" height="17" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908C16.658 14.013 17.64 11.705 17.64 9.2z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/></svg>
        Google
      </button>
    </div>

    <div class="card-footer">
      <div class="dot"></div>
      <p>© 2026 TicketPrime — Todos os direitos reservados</p>
    </div>

  </div>
</div>

<script>
  function switchTab(tab) {
    ['login','register'].forEach(t => {
      document.getElementById('tab-' + t).classList.toggle('active', t === tab);
      document.getElementById('form-' + t).classList.toggle('active', t === tab);
    });
  }

  function checkStrength(input) {
    const field = document.getElementById('pass-field');
    field.classList.remove('str-weak','str-med','str-strong');
    const v = input.value;
    if (!v) return;
    if (v.length < 6) field.classList.add('str-weak');
    else if (v.length < 10) field.classList.add('str-med');
    else field.classList.add('str-strong');
  }
</script>
</body>
</html>